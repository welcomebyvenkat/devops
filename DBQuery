WITH latest_rows AS (
    SELECT t.*,
           ROW_NUMBER() OVER (
               PARTITION BY t.source_authorization_num, t.line_item_number
               ORDER BY t.load_id DESC
           ) rn
    FROM TRUCARE_STG_OWN.TRUCARE_AUTH_BULK_LOAD_HISTORY t
    WHERE t.source_authorization_num = '147968733'
)
SELECT l.load_id,
       l.source_authorization_num,
       l.line_item_number,
       l.status,
       l.errordescription
FROM latest_rows l
WHERE l.rn = 1
  AND UPPER(TRIM(l.status)) = 'FAILURE'
  AND NOT (
      LOWER(NVL(l.errordescription,'')) LIKE '%duplicate%'
      AND EXISTS (
          SELECT 1
          FROM TRUCARE_STG_OWN.TRUCARE_AUTH_BULK_LOAD_HISTORY s
          WHERE s.source_authorization_num = l.source_authorization_num
            AND NVL(s.line_item_number, -1) = NVL(l.line_item_number, -1)
            AND UPPER(TRIM(s.status)) = 'SUCCESS'
      )
  )
ORDER BY l.line_item_number;
