import org.apache.commons.csv.*;

import java.io.*;
import java.nio.charset.StandardCharsets;
import java.util.ArrayList;
import java.util.List;

public class CsvReaderUtil {

    public static List<MedicaidRecord> readCsv(String filePath) throws Exception {

        List<MedicaidRecord> list = new ArrayList<>();

        try (
                Reader reader = new InputStreamReader(new FileInputStream(filePath), StandardCharsets.UTF_8);
                CSVParser parser = CSVFormat.DEFAULT
                        .builder()
                        .setHeader()                 // uses first row as header
                        .setSkipHeaderRecord(true)
                        .build()
                        .parse(reader)
        ) {

            for (CSVRecord record : parser) {

                String medicaidId = record.get("medicaid_id");
                String authName   = record.get("Auth name");
                String noteText   = record.get("note text");

                list.add(new MedicaidRecord(
                        medicaidId != null ? medicaidId.trim() : "",
                        authName != null ? authName.trim() : "",
                        noteText != null ? noteText.trim() : ""
                ));
            }
        }

        return list;
    }
}


public static List<String> readMedicaidList(String filePath) throws Exception {

    List<String> list = new ArrayList<>();

    try (
            Reader reader = new InputStreamReader(new FileInputStream(filePath), StandardCharsets.UTF_8);
            CSVParser parser = CSVFormat.DEFAULT
                    .builder()
                    .setHeader()
                    .setSkipHeaderRecord(true)
                    .build()
                    .parse(reader)
    ) {

        for (CSVRecord record : parser) {
            String medicaid = record.get(0);

            if (medicaid != null && !medicaid.trim().isEmpty()) {
                list.add(medicaid.trim());
            }
        }
    }

    return list;
}


public static void main(String[] args) throws Exception {

    List<MedicaidRecord> records = readCsv("C:/input/excel1.csv");
    List<String> medicaidList = readMedicaidList("C:/input/excel2.csv");

    System.out.println("Excel1 records: " + records.size());
    System.out.println("Excel2 records: " + medicaidList.size());
}
