import org.apache.commons.csv.CSVFormat;
import org.apache.commons.csv.CSVParser;
import org.apache.commons.csv.CSVPrinter;
import org.apache.commons.csv.CSVRecord;

import java.io.*;
import java.nio.charset.StandardCharsets;
import java.util.HashSet;
import java.util.Set;

public class CsvMatcher {

    public static void main(String[] args) throws Exception {

        String file1 = "C:/input/excel1.csv";
        String file2 = "C:/input/excel2.csv";
        String output = "C:/output/matched.csv";

        Set<String> medicaidSet = new HashSet<>();

        // Read file2
        try (
                Reader reader2 = new InputStreamReader(new FileInputStream(file2), StandardCharsets.UTF_8);
                CSVParser parser2 = CSVFormat.DEFAULT
                        .builder()
                        .setHeader()
                        .setSkipHeaderRecord(true)
                        .build()
                        .parse(reader2)
        ) {
            for (CSVRecord record : parser2) {
                String medicaid = record.get(0);
                if (medicaid != null && !medicaid.trim().isEmpty()) {
                    medicaidSet.add(medicaid.trim());
                }
            }
        }

        // Read file1 and write matches
        try (
                Reader reader1 = new InputStreamReader(new FileInputStream(file1), StandardCharsets.UTF_8);
                CSVParser parser1 = CSVFormat.DEFAULT
                        .builder()
                        .setHeader()
                        .setSkipHeaderRecord(true)
                        .build()
                        .parse(reader1);

                Writer writer = new OutputStreamWriter(new FileOutputStream(output), StandardCharsets.UTF_8);
                CSVPrinter printer = new CSVPrinter(writer, CSVFormat.DEFAULT)
        ) {
            // write header
            printer.printRecord(parser1.getHeaderNames());

            for (CSVRecord record : parser1) {
                String medicaidId = record.get(0);

                if (medicaidId != null && medicaidSet.contains(medicaidId.trim())) {
                    printer.printRecord(record);
                }
            }
        }

        System.out.println("Done!");
    }
}
